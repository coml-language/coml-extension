# Example of a manifest package using COML
{[package]}
name = "coml-example"
version = "0.1.0"
edition = { workspace = true }

#:
    Two ways to declare dependencies in COML:
    
    1. INLINE: Single-line for simple declarations.
       {[dependencies]} -> coml = { version = "*", features = ["full"] }
       
    2. DEPLOYED: Sub-table for complex configurations.
       {[dependencies.name]} -> version = "*"
:#

{[dependencies]}
coml = { version = "*", default-features = false, features = ["full"] }

{[dependencies.coml-util]}
version = "*"
default-features = false
features = ["std"]