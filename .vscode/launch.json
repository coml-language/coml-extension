{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Extension (COML)",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/editors/vscode"
            ],
            "outFiles": [
                "${workspaceFolder}/editors/vscode/out/**/*.js"
            ],
            "env": {
                // On pointe directement vers le binaire compilé par Cargo
                "SERVER_PATH": "${workspaceFolder}/target/debug/coml-server",
                "RUST_LOG": "debug"
            },
        }
    ]
}