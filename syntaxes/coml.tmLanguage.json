{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "COML",
    "scopeName": "source.coml",
    "patterns": [
        { "include": "#comments" }
    ],
    "repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.block.coml",
					"begin": "#:",
					"end": ":#"
				},
				{
					"name": "comment.line.number-sign.coml",
					"match": "#.*$"
				}
			]
		}
	}
}