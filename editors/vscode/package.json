{
  "name": "coml",
  "displayName": "Coml",
  "description": "Coml Language support for Vscode.",
  "version": "0.1.3",
  "publisher": "coml-lang",
  "private": true,
  "preview": true,
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/coml-language/coml-extension.git"
  },
  "icon": "icons/coml-icon.png",
  "galleryBanner": {
    "color": "#653823",
    "theme": "dark"
  },
  "keywords": [
    "coml",
    "syntax",
    "formatter",
    "config"
  ],
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "activationEvents": [
    "onLanguage:coml"
  ],
  "license": "MIT OR Apache-2.0",
  "engines": {
    "vscode": "^1.108.0"
  },
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "package": "vcse package -o coml.vsix"
    
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@tsconfig/strictest": "^2.0.5",
    "@types/node": "~25.0.x",
    "@types/vscode": "~1.108.0",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.27.2",
    "typescript": "^5.7.3"
  },
  "contributes": {
    "grammars": [
      {
        "language": "coml",
        "scopeName": "source.id",
        "path": "./syntaxes/coml.tmLanguage.json"
      }
    ],
    "languages": [
      {
        "id": "coml",
        "aliases": [
          "COML"
        ],
        "extensions": [
          ".coml"
        ],
        "configuration": "./language-configuration.json"
      }
    ]
  }
}