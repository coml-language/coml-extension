{
  "name": "coml",
  "displayName": "COML",
  "version": "0.1.0",
  "publisher": "coml",
  "icon": "icons/coml-icon.png",
  "engines": {
    "vscode": "^1.100.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/coml-lang/coml-extension.git"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters"
  ],
  "contributes": {
    "languages": [
      {
        "id": "coml",
        "aliases": [
          "COML",
          "coml"
        ],
        "extensions": [
          ".coml"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "coml",
        "scopeName": "source.coml",
        "path": "./syntaxes/coml.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "compile": "npx tsc -p ./"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "@types/vscode": "^1.100.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}