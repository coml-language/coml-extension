{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "COML",
    "scopeName": "source.coml",
    "patterns": [
        { "include": "#comments" },
        { "include": "#interpolation" },
        { "include": "#table-headers" },
        { "include": "#keys" },
        { "include": "#values" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.block.coml",
                    "begin": "#:",
                    "end": ":#"
                },
                {
                    "name": "comment.line.number-sign.coml",
                    "match": "#.*$"
                }
            ]
        },
        "interpolation": {
            "name": "variable.interpolation.coml",
            "begin": "\\{\\{",
            "end": "\\}\\}",
            "beginCaptures": {
                "0": { "name": "punctuation.section.interpolation.begin.coml" }
            },
            "endCaptures": {
                "0": { "name": "punctuation.section.interpolation.end.coml" }
            },
            "patterns": [
                {
                    "name": "variable.other.readwrite.coml",
                    "match": "[A-Za-z0-9_-]+"
                }
            ]
        },
        "table-headers": {
            "patterns": [
                {
                    "name": "meta.section.table.coml",
                    "match": "^\\s*(\\{)(\\[)([A-Za-z0-9_\\.-]+)(\\])(\\})",
                    "captures": {
                        "1": { "name": "punctuation.section.embedded.begin.coml" },
                        "2": { "name": "punctuation.definition.array.begin.coml" },
                        "3": { "name": "entity.name.section.coml" },
                        "4": { "name": "punctuation.definition.array.end.coml" },
                        "5": { "name": "punctuation.section.embedded.end.coml" }
                    }
                }
            ]
        },
        "keys": {
            "match": "\\b([A-Za-z0-9_\\.-]+)\\s*(?==)",
            "captures": {
                "1": { "name": "variable.key.coml" }
            }
        },
        "values": {
            "patterns": [
                { "match": "=", "name": "punctuation.separator.key-value.coml" },
                { "include": "#interpolation" },
                { "include": "#strings" },
                { "include": "#numbers" },
                { "include": "#booleans" },
                { "include": "#inline-tables" },
                { "include": "#arrays" },
                { "include": "#comments" }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.coml",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        { "include": "#interpolation" },
                        { "name": "constant.character.escape.coml", "match": "\\\\." }
                    ]
                }
            ]
        },
        "numbers": {
            "name": "constant.numeric.coml",
            "match": "\\b\\d+(\\.\\d+)?\\b"
        },
        "booleans": {
            "name": "constant.language.boolean.coml",
            "match": "\\b(true|false|workspace)\\b"
        },
        "inline-tables": {
            "begin": "\\{",
            "end": "\\}",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.table.inline.begin.coml" }
            },
            "endCaptures": {
                "0": { "name": "punctuation.definition.table.inline.end.coml" }
            },
            "patterns": [
                { "include": "#keys" },
                { "include": "#values" }
            ]
        },
        "arrays": {
            "begin": "\\[",
            "end": "\\]",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.array.begin.coml" }
            },
            "endCaptures": {
                "0": { "name": "punctuation.definition.array.end.coml" }
            },
            "patterns": [
                { "include": "#values" }
            ]
        }
    }
}